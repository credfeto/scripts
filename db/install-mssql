#! /bin/sh

die() {
    if [ -t 2 ]; then
        printf '\n\033[31m✗\033[0m %s\n' "$*" >&2
    else
        printf '\n✗ %s\n' "$*" >&2
    fi
    exit 1
}

success() {
    if [ -t 1 ]; then
        printf '\n\033[32m✓\033[0m %s\n' "$*"
    else
        printf '\n✓ %s\n' "$*"
    fi
}

info() {
    if [ -t 1 ]; then
        printf '\n\033[32m→\033[0m %s\n' "$*"
    else
        printf '\n→ %s\n' "$*"
    fi
}

BASEDIR="$(dirname "$(readlink -f "$0")")"
info "Script Dir: $BASEDIR"

cd "$BASEDIR" || die "Could not select $BASEDIR"

# Not following:
# shellcheck disable=1091
. "$BASEDIR/dbenv"

SHARED_DATA=/db/mssql/
while [ $# -gt 0 ]; do
  key="$1"

  case $key in
    -X|--data)
      SHARED_DATA="$2"
      shift # past argument
      shift # past value
      ;;
    *)    # unknown option - skip here
      shift # past argument
      ;;
  esac
done

[ -z "$PASSWORD" ] && die "--password not specified"
[ -z "$SHARED_DATA" ] && die "--data not specified"


info "Ensuring Data exists"
sudo mkdir -p "$SHARED_DATA/data"
sudo mkdir -p "$SHARED_DATA/logs"
sudo mkdir -p "$SHARED_DATA/secrets"

info "Ensuring docker has permission to access $SHARED_DATA"
sudo chown -R 10001:docker "$SHARED_DATA"
sudo chmod -R 700 "$SHARED_DATA"

{
  printf 'PASSWORD=%s\n' "$PASSWORD"
  printf 'SHARED_DATA=%s\n' "$SHARED_DATA"
} > "$BASEDIR/.env"
sudo docker compose pull || die "Could not get mssql container"
sudo docker compose up -d || die "Could not start mssql"
rm -f "$BASEDIR/.env"
success "mssql started"
